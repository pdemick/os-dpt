# Braintrust tracing for the chat-to-SQL agent. Optional and development-
# oriented — used to inspect agent turns and refine prompts.
#
# Preferred: set the key in the app under Settings → AI providers →
# Observability (stored encrypted in the vault). This env var is an OVERRIDE
# for CI / one-offs and takes precedence over the vaulted key when set.
# Leave unset to disable entirely (the braintrust SDK is then never loaded).
# `pnpm dev` auto-loads a .env at the repo root or in server/.
BRAINTRUST_API_KEY=

# Braintrust project to log traces under. Defaults to "os-dpt".
BRAINTRUST_PROJECT=os-dpt
